# ── Database (Neon PostgreSQL) ──
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Redis (Upstash) ──
UPSTASH_REDIS_REST_URL="https://YOUR-DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_TOKEN"
REDIS_URL="rediss://default:YOUR_TOKEN@YOUR-DB.upstash.io:6379"

# ── JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ──
JWT_SECRET="CHANGE_ME_generate_64_byte_hex"
JWT_ADMIN_SECRET="CHANGE_ME_generate_64_byte_hex_different"

# ── WhatsApp (Meta Cloud API) ──
WA_VERIFY_TOKEN="YOUR_WEBHOOK_VERIFY_TOKEN"
WA_APP_SECRET="YOUR_META_APP_SECRET"

# ── SMS OTP (MSG91) ──
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""

# ── Razorpay ──
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ── App Config ──
NODE_ENV="development"
API_PORT=3001
WEBHOOK_PORT=3002
WORKER_CONCURRENCY=5

# ── Frontend ──
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="http://localhost:3001"

# ── S3 / MinIO (for media uploads) ──
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="whatsapp-crm-media"
S3_REGION="ap-south-1"

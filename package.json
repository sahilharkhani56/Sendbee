{
  "name": "whatsapp-crm",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant WhatsApp CRM SaaS for Indian SMBs",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @whatsapp-crm/database generate",
    "db:migrate": "pnpm --filter @whatsapp-crm/database migrate:dev",
    "db:seed": "pnpm --filter @whatsapp-crm/database seed",
    "db:studio": "pnpm --filter @whatsapp-crm/database studio"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "bcrypt"
    ]
  }
}

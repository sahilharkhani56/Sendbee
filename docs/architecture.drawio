        </mxCell>
        <mxCell id="ws-server" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=10;" value="WebSocket Server (Socket.io)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;• Redis Adapter (multi-instance)&#xa;• Room per tenant for isolation&#xa;• Events: new_message, status_update,&#xa;  appointment_booked, notification&#xa;• Auth: JWT verified on connect&#xa;• Heartbeat: 25s interval" vertex="1">

        <mxCell id="bullmq-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;" value="BullMQ (Redis-backed) — MVP&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Queues: message_send (priority) | webhook_process | campaign_execute | reminder_check | analytics_aggregate | dead_letter&#xa;Features: Delayed jobs, Exponential backoff, Concurrency control, Job progress tracking, Repeatable jobs" vertex="1">
          <mxGeometry height="65" width="620" x="120" y="685" as="geometry" />
        </mxCell>
        <mxCell id="kafka-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;dashed=1;" value="Apache Kafka (AWS MSK) — Phase 2+&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Topics: whatsapp.webhook.raw | whatsapp.message.outbound | analytics.events | crm.contact.events | appointment.events | dlq.failed&#xa;Benefits: Event replay, Multiple consumers, 100K+ msg/sec, 7-day retention, Exactly-once semantics" vertex="1">
